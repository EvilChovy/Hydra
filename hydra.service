[Unit]
Description=HYDRA Trading Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/hydra
EnvironmentFile=/home/pi/hydra/.env
ExecStart=/home/pi/hydra/.venv/bin/python main.py
Restart=always
RestartSec=15

# Log to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hydra-bot

[Install]
WantedBy=multi-user.target
